# ── Backend Environment Variables ────────────────────────────────────────────
# Copy this file to backend/.env and fill in your values

PORT=5000

# JWT secret — use any long random string in production
JWT_SECRET=talent_nest_super_secret_jwt_key_2024

# Frontend URL (for CORS)
# Local dev:
FRONTEND_URL=http://localhost:5173
# Production (replace with your Vercel URL after deploying frontend):
# FRONTEND_URL=https://your-app.vercel.app

# MongoDB Atlas connection string (REQUIRED for production — data persists)
# Steps: https://www.mongodb.com/atlas → Create free cluster → Connect → Copy URI
# Paste your full connection string below (includes username & password):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/talentnest?retryWrites=true&w=majority

# Email (Resend) — get free key at https://resend.com (3,000 emails/mo free)
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Backend public URL — used in email tracking pixel links (set to your Railway URL)
BACKEND_URL=https://api.talentnesthr.com

# Cookie secret — used to sign session cookies (use a long random string)
COOKIE_SECRET=change_me_to_a_long_random_string

# Super admin seed password (optional override — default: TalentNest@2024)
# SUPER_ADMIN_PASSWORD=your_secure_password

# Twilio WhatsApp (optional — only needed if using WhatsApp notifications)
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
