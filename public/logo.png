<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Talent Nest HR | PNG Portal</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
    <style>
        :root { --cobalt: #002e5d; --gold: #a68966; --slate: #4a4a4a; }
        body { font-family: 'Inter', sans-serif; background: #0f172a; margin: 0; display: flex; height: 100vh; overflow: hidden; }
        .sidebar { width: 380px; background: white; padding: 20px; overflow-y: auto; border-right: 1px solid #e2e8f0; flex-shrink: 0; }
        .sidebar h2 { font-size: 1.1rem; color: var(--cobalt); margin-bottom: 15px; border-bottom: 3px solid var(--gold); padding-bottom: 8px; }
        .section-tag { background: #e2e8f0; color: var(--cobalt); padding: 4px 8px; font-size: 0.6rem; font-weight: 800; border-radius: 4px; display: block; margin: 15px 0 8px; text-transform: uppercase; }
        .field { margin-bottom: 8px; }
        label { display: block; font-size: 0.65rem; font-weight: 700; color: var(--slate); margin-bottom: 2px; }
        input, textarea { width: 100%; padding: 7px; border: 1.2px solid #cbd5e1; border-radius: 4px; font-size: 0.8rem; box-sizing: border-box; }
        .btn-generate { background: #d946ef; color: white; border: none; padding: 12px; width: 100%; border-radius: 6px; font-weight: 800; cursor: pointer; margin-top: 20px; box-shadow: 0 4px 10px rgba(217, 70, 239, 0.3); }

        .preview-pane { flex: 1; padding: 20px; overflow-y: auto; background: #1e293b; display: flex; flex-direction: column; align-items: center; }
        #capture-area { background: #1e293b; }

        .pdf-page { 
            width: 8.27in; height: 11.68in; background: white !important; 
            padding: 0.7in 0.8in; position: relative; color: #111; 
            font-family: 'Times New Roman', Times, serif; font-size: 10.5pt; 
            line-height: 1.4; box-sizing: border-box; overflow: hidden;
            display: flex; flex-direction: column; margin-bottom: 30px;
        }

        .watermark { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%) rotate(-45deg); font-size: 65pt; font-weight: 900; color: rgba(0, 0, 0, 0.03); z-index: 0; pointer-events: none; white-space: nowrap; text-transform: uppercase; }
        .header-wrap { display: flex; justify-content: space-between; align-items: flex-end; border-bottom: 2px solid var(--cobalt); padding-bottom: 10px; margin-bottom: 15px; }
        .logo-box img { max-height: 50px; max-width: 200px; }
        .meta-box { text-align: right; font-family: Arial; font-size: 8.5pt; line-height: 1.3; }
        .footer-wrap { position: absolute; bottom: 0.4in; left: 0.8in; right: 0.8in; border-top: 1px solid #ddd; padding-top: 8px; text-align: center; }
        .footer-content { font-family: Arial; font-size: 8pt; color: #666; white-space: pre-line; }
        .subject-box { background: #f8fafc; padding: 8px; border-left: 4px solid var(--cobalt); font-weight: bold; margin: 10px 0; font-family: sans-serif; font-size: 9.5pt; text-transform: uppercase; }
        .salary-table { width: 100%; border-collapse: collapse; margin: 8px 0; font-family: Arial; font-size: 9.5pt; }
        .salary-table th, .salary-table td { border: 1px solid #333; padding: 6px; text-align: left; }
        .salary-table th { background: #f1f5f9; }

        .execution-table { width: 100%; margin-top: auto; margin-bottom: 60px; border: none; }
        .execution-table td { vertical-align: bottom; border: none; padding: 0; }
        .sig-space { height: 65px; position: relative; margin: 5px 0; }
        #uploaded-sig { position: absolute; top: 50%; left: 0; transform: translateY(-50%); height: 75px; display: none; mix-blend-mode: multiply; }
        .sig-box { border: 1.2px solid #000; padding: 12px; width: 250px; font-size: 9pt; background: #fff; float: right; box-sizing: border-box; }
        .sig-row { border-top: 1px solid #000; margin-top: 40px; padding-top: 4px; font-weight: bold; font-size: 8pt; text-align: left; }

        p, li { text-align: justify; margin-bottom: 6px; }
        h4 { margin: 12px 0 4px 0; font-size: 10.5pt; border-bottom: 1px solid #eee; display: inline-block; color: var(--cobalt); }
    </style>
</head>
<body>

<div class="sidebar">
    <h2>PNG GENERATOR</h2>
    <span class="section-tag">1. IDENTITY</span>
    <div class="field"><label>Logo</label><input type="file" accept="image/*" onchange="loadLogo(event)"></div>
    <div class="field"><label>Signature</label><input type="file" accept="image/*" onchange="loadSignature(event)"></div>
    <div class="field"><label>Company</label><input type="text" id="coIn" value="Talent Nest HR" oninput="sync()"></div>

    <span class="section-tag">2. CANDIDATE</span>
    <div class="field"><label>Name</label><input type="text" id="nameIn" value="Choppa Gowri Priya" oninput="sync()"></div>
    <div class="field"><label>Designation</label><input type="text" id="roleIn" value="Business Development Manager" oninput="sync()"></div>
    
    <span class="section-tag">3. JD UPDATE</span>
    <div class="field"><textarea id="rolesIn" rows="4" oninput="sync()">Detailed roles and responsibilities text goes here...</textarea></div>

    <button class="btn-generate" onclick="downloadPNG()">DOWNLOAD AS PNG</button>
</div>

<div class="preview-pane">
    <div id="capture-area">
        <div class="pdf-page" id="page-1">
            <div class="watermark outCo">TALENT NEST HR</div>
            <div class="header-wrap">
                <div class="logo-box"><img class="logo-img" src="https://via.placeholder.com/180x50?text=LOGO" alt="Logo"></div>
                <div class="meta-box"><strong>OFFER OF EMPLOYMENT</strong></div>
            </div>
            <p><strong>To, Ms. <span id="outName"></span></strong></p>
            <div class="subject-box">Subject: Offer for "<span id="outRole"></span>"</div>
            <h4>4. ROLES & RESPONSIBILITIES</h4>
            <p id="outRolesText"></p>
            <div class="footer-wrap"><div class="footer-content">Page 1</div></div>
        </div>

        <div class="pdf-page" id="page-2">
            <div class="watermark outCo">TALENT NEST HR</div>
            <div class="header-wrap">
                <div class="logo-box"><img class="logo-img" src="https://via.placeholder.com/180x50?text=LOGO" alt="Logo"></div>
                <div class="meta-box"><strong>ANNEXURE - A</strong></div>
            </div>
            <h4>10. GOVERNING LAW</h4>
            <p>This offer is governed by the laws of India.</p>

            <table class="execution-table">
                <tr>
                    <td>
                        <p>Yours Sincerely,<br>For <strong><span class="outCoSpan"></span></strong></p>
                        <div class="sig-space"><img id="uploaded-sig" src=""></div>
                        <p>Managing Director</p>
                    </td>
                    <td>
                        <div class="sig-box">
                            <p style="text-align: center; font-weight: bold;">CANDIDATE ACCEPTANCE</p>
                            <div class="sig-row">Signature</div>
                            <div style="margin-top: 10px;"><strong>Name:</strong> <span id="outName4"></span></div>
                            <div style="margin-top: 10px;"><strong>Date:</strong> _________________</div>
                        </div>
                    </td>
                </tr>
            </table>
            <div class="footer-wrap"><div class="footer-content">Page 2</div></div>
        </div>
    </div>
</div>

<script>
    function loadLogo(e) {
        const reader = new FileReader();
        reader.onload = (event) => { document.querySelectorAll('.logo-img').forEach(img => img.src = event.target.result); };
        reader.readAsDataURL(e.target.files[0]);
    }

    function loadSignature(e) {
        const reader = new FileReader();
        reader.onload = (event) => { 
            const sig = document.getElementById('uploaded-sig');
            sig.src = event.target.result;
            sig.style.display = 'block';
        };
        reader.readAsDataURL(e.target.files[0]);
    }

    function sync() {
        const get = (id) => document.getElementById(id).value;
        document.querySelectorAll('.outCo').forEach(el => el.innerText = get('coIn'));
        document.getElementById('outName').innerText = get('nameIn');
        document.getElementById('outName4').innerText = get('nameIn');
        document.getElementById('outRole').innerText = get('roleIn');
        document.getElementById('outRolesText').innerText = get('rolesIn');
    }

    async function downloadPNG() {
        const pages = ['page-1', 'page-2'];
        for (let id of pages) {
            const canvas = await html2canvas(document.getElementById(id), { scale: 3 });
            const link = document.createElement('a');
            link.download = `${id}.png`;
            link.href = canvas.toDataURL("image/png");
            link.click();
        }
    }
    window.onload = sync;
</script>
</body>
</html>