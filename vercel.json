{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://talentnest-hr.onrender.com/api/:path*" },

    { "source": "/sitemap.xml",        "destination": "https://talentnest-hr.onrender.com/sitemap.xml" },
    { "source": "/sitemap-jobs.xml",   "destination": "https://talentnest-hr.onrender.com/sitemap-jobs.xml" },
    { "source": "/sitemap-pages.xml",  "destination": "https://talentnest-hr.onrender.com/sitemap-pages.xml" },
    { "source": "/careers/jobs.xml",   "destination": "https://talentnest-hr.onrender.com/careers/jobs.xml" },
    { "source": "/careers/jobs.json",  "destination": "https://talentnest-hr.onrender.com/careers/jobs.json" },
    { "source": "/jobs.xml",           "destination": "https://talentnest-hr.onrender.com/jobs.xml" },
    { "source": "/robots.txt",         "destination": "https://talentnest-hr.onrender.com/robots.txt" },

    { "source": "/careers/job/:slug",  "destination": "https://talentnest-hr.onrender.com/careers/job/:slug" },
    { "source": "/careers/crawl",      "destination": "https://talentnest-hr.onrender.com/careers/crawl" },

    { "source": "/:orgSlug/careers",   "destination": "/index.html" },
    { "source": "/:orgSlug/careers/",  "destination": "/index.html" },

    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",  "value": "nosniff" },
        { "key": "X-Frame-Options",          "value": "SAMEORIGIN" },
        { "key": "X-XSS-Protection",         "value": "1; mode=block" },
        { "key": "Referrer-Policy",          "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",       "value": "camera=(), microphone=(self), geolocation=(self)" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*\\.js|.*\\.css|.*\\.woff2?|.*\\.png|.*\\.svg|.*\\.webp|.*\\.avif)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/sitemap(.*)\\.xml",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=3600" },
        { "key": "Content-Type",  "value": "application/xml; charset=utf-8" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" },
        { "key": "Content-Type",  "value": "text/plain; charset=utf-8" }
      ]
    },
    {
      "source": "/:orgSlug/careers",
      "headers": [
        { "key": "X-Frame-Options",         "value": "ALLOWALL" },
        { "key": "Content-Security-Policy", "value": "frame-ancestors *" }
      ]
    }
  ]
}
